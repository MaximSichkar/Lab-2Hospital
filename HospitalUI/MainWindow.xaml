<Window x:Class="HospitalUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HospitalUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
	<Grid Margin="10">

		<DataGrid ItemsSource="{Binding Appointments}"
          SelectedItem="{Binding SelectedAppointment}"
          AutoGenerateColumns="False"
          MouseDoubleClick="Edit_Click">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Дата" Binding="{Binding DateTime}"/>
				<DataGridTextColumn Header="Лікар" Binding="{Binding Doctor.Name}"/>
				<DataGridTextColumn Header="Пацієнт" Binding="{Binding Patient.Name}"/>
			</DataGrid.Columns>
		</DataGrid>
		<Button Content="Видалити" Click="Delete_Click" Height="55" Margin="600,351,41,8"/>
		<Button Content="Додати" Click="Add_Click" Height="53" RenderTransformOrigin="0.524,0.538" Margin="451,353,205,8"/>
	</Grid>
</Window>
