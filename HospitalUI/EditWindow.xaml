<Window x:Class="HospitalUI.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HospitalUI"
        mc:Ignorable="d"
        Title="EditWindow" Height="450" Width="800">
    <Grid>
		<DatePicker SelectedDate="{Binding Appointment.DateTime}"/>

		<ComboBox ItemsSource="{Binding Doctors}"
				  SelectedItem="{Binding SelectedDoctor}"
				  DisplayMemberPath="Name" Margin="10,31,693,301"/>

		<ComboBox ItemsSource="{Binding Patients}"
				  SelectedItem="{Binding SelectedPatient}"
				  DisplayMemberPath="Name" Margin="141,31,531,301"/>
		<Button Content="Зберегти" Click="Save_Click" Margin="0,362,0,25"/>
		<Label Content="Select Patient" Margin="141,0,572,408"/>
	</Grid>
</Window>
